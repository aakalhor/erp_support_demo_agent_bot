# Telegram bot token from BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# Base URL of the local RAG HTTP API
API_BASE_URL=http://localhost:8080

# Local whisper CLI command. Examples:
#   whisper-cli       (whisper.cpp default)
#   ./main            (whisper.cpp build output)
#   faster-whisper    (if you wrap faster-whisper in a CLI)
WHISPER_COMMAND=whisper-cli

# Path to the local whisper.cpp model (ggml *.bin)
# Download: https://github.com/ggerganov/whisper.cpp#quick-start
WHISPER_MODEL_PATH=./models/ggml-base.en.bin

# ffmpeg binary on PATH (or absolute path on Windows, e.g. C:\ffmpeg\bin\ffmpeg.exe)
FFMPEG_PATH=ffmpeg

# Default client_id used by the Telegram bot when sending /ask
DEFAULT_CLIENT_ID=global

# HTTP API port
PORT=8080

# Optional: working directory for ephemeral voice files
TMP_DIR=./tmp

# Optional: path overrides
SEED_PATH=./data/seed_faq.jsonl
INDEX_PATH=./storage/index.json
